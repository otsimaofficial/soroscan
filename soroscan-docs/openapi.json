openapi: 3.0.3
info:
  title: SoroScan API
  version: 1.0.0
  description: REST API documentation for SoroScan, a Stellar Soroban smart contract
    indexer.
paths:
  /api/analytics/rate-limits/:
    get:
      operationId: api_analytics_rate_limits_retrieve
      description: Return 7-day API key usage analytics from Redis-backed counters.
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RateLimitAnalyticsResponse'
          description: ''
  /api/audit-trail/:
    get:
      operationId: api_audit_trail_list
      description: Query immutable admin audit trail entries.
      parameters:
      - in: query
        name: action
        schema:
          type: string
          minLength: 1
      - in: query
        name: limit
        schema:
          type: integer
      - in: query
        name: object_id
        schema:
          type: string
          minLength: 1
      - in: query
        name: object_type
        schema:
          type: string
          minLength: 1
      - in: query
        name: since
        schema:
          type: string
          format: date-time
      - in: query
        name: until
        schema:
          type: string
          format: date-time
      - in: query
        name: user
        schema:
          type: string
          minLength: 1
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/AdminAction'
          description: ''
  /api/contracts/status/:
    get:
      operationId: api_contracts_status_retrieve
      description: Return aggregate contract and event indexing snapshot statistics.
      tags:
      - api
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ContractStatusResponse'
          description: ''
  /api/ingest/admin/ingest-errors/:
    get:
      operationId: api_ingest_admin_ingest_errors_retrieve
      description: Get recent ingest errors (admin only).
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/ingest/admin/organization-costs/:
    get:
      operationId: api_ingest_admin_organization_costs_retrieve
      description: Admin endpoint exposing per-organization cost snapshots and budget
        state.
      parameters:
      - in: query
        name: month
        schema:
          type: string
          minLength: 1
      - in: query
        name: organization_id
        schema:
          type: integer
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrganizationCostBreakdownResponse'
          description: ''
  /api/ingest/api-keys/:
    get:
      operationId: api_ingest_api_keys_list
      description: |-
        ViewSet for managing API keys with tiered rate limiting.

        Endpoints:
        - GET /api-keys/ - List your API keys
        - POST /api-keys/ - Create a new API key
        - GET /api-keys/{id}/ - Get key details (key value shown only on creation)
        - DELETE /api-keys/{id}/ - Revoke an API key
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAPIKeyList'
          description: ''
    post:
      operationId: api_ingest_api_keys_create
      description: |-
        ViewSet for managing API keys with tiered rate limiting.

        Endpoints:
        - GET /api-keys/ - List your API keys
        - POST /api-keys/ - Create a new API key
        - GET /api-keys/{id}/ - Get key details (key value shown only on creation)
        - DELETE /api-keys/{id}/ - Revoke an API key
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/APIKey'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/APIKey'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/APIKey'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/APIKey'
          description: ''
  /api/ingest/api-keys/{id}/:
    get:
      operationId: api_ingest_api_keys_retrieve
      description: |-
        ViewSet for managing API keys with tiered rate limiting.

        Endpoints:
        - GET /api-keys/ - List your API keys
        - POST /api-keys/ - Create a new API key
        - GET /api-keys/{id}/ - Get key details (key value shown only on creation)
        - DELETE /api-keys/{id}/ - Revoke an API key
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/APIKey'
          description: ''
    delete:
      operationId: api_ingest_api_keys_destroy
      description: |-
        ViewSet for managing API keys with tiered rate limiting.

        Endpoints:
        - GET /api-keys/ - List your API keys
        - POST /api-keys/ - Create a new API key
        - GET /api-keys/{id}/ - Get key details (key value shown only on creation)
        - DELETE /api-keys/{id}/ - Revoke an API key
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/ingest/audit-trail/:
    get:
      operationId: api_ingest_audit_trail_list
      description: Query immutable admin audit trail entries.
      parameters:
      - in: query
        name: action
