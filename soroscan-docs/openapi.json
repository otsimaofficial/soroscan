        json_schema:
          nullable: true
          description: Optional JSON Schema used to validate ingested event payloads.
        is_active:
          type: boolean
          description: Whether indexing is active
        deprecation_status:
          allOf:
          - $ref: '#/components/schemas/DeprecationStatusEnum'
          description: |-
            Manual lifecycle/deprecation state for warning users

            * `active` - Active
            * `deprecated` - Deprecated
            * `suspended` - Suspended
        deprecation_reason:
          type: string
          description: Optional reason shown to users when contract is deprecated/suspended
        max_events_per_minute:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
          nullable: true
          description: Max events per minute for ingest-time rate limiting (None =
            unlimited)
        event_filter_type:
          allOf:
          - $ref: '#/components/schemas/EventFilterTypeEnum'
          description: |-
            Ingest filter mode: none = store all events; whitelist = only store listed event types; blacklist = drop listed event types.

            * `none` - No Filter
            * `whitelist` - Whitelist
            * `blacklist` - Blacklist
        event_filter_list:
          description: List of event type names used by the whitelist/blacklist filter.
        metadata:
          description: Custom attributes for storing contract metadata (team, owner,
            cost center, etc.)
        last_indexed_ledger:
          type: integer
          readOnly: true
          nullable: true
          description: Last ledger sequence that was indexed for this contract
        team:
          type: integer
          nullable: true
        event_count:
          type: integer
          readOnly: true
        last_event_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
          description: Timestamp of the last indexed event for this contract
        warnings:
          type: array
          items:
            type: object
            additionalProperties:
              type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - contract_id
      - created_at
      - event_count
      - id
      - last_event_at
      - last_indexed_ledger
      - name
      - updated_at
      - warnings
    Unauthorized:
      type: object
      properties:
        detail:
          type: string
      required:
      - detail
    ValidationStatusEnum:
      enum:
      - passed
      - failed
      type: string
      description: |-
        * `passed` - Passed
        * `failed` - Failed
    VulnerabilityImpactResponse:
      type: object
      properties:
        contract_id:
          type: string
        affected_contracts: {}
        impacted_count:
          type: integer
        risk_score:
          type: number
          format: double
        impact_level:
          type: string
        has_cycles:
          type: boolean
      required:
      - affected_contracts
      - contract_id
      - has_cycles
      - impact_level
      - impacted_count
      - risk_score
    WebhookConditionDryRunRequest:
      type: object
      properties:
        sample_event: {}
      required:
      - sample_event
    WebhookConditionDryRunResponse:
      type: object
      properties:
        matched:
          type: boolean
      required:
      - matched
    WebhookSubscription:
      type: object
      description: |-
        Serializer for WebhookSubscription model.
        Configures endpoints to receive event payloads when matches occur.
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
          description: Contract to monitor
        contract_id:
          type: string
          readOnly: true
        event_type:
          type: string
          description: Event type filter (blank = all events)
          maxLength: 100
        target_url:
          type: string
          format: uri
          description: URL to POST event data to
          maxLength: 200
        is_active:
          type: boolean
        signature_algorithm:
          allOf:
          - $ref: '#/components/schemas/SignatureAlgorithmEnum'
          description: |-
            HMAC algorithm used for X-SoroScan-Signature header.

            * `sha256` - SHA-256
            * `sha1` - SHA-1 (legacy)
        ack_header_name:
          type: string
          description: HTTP response header that must be present to acknowledge receipt.
          maxLength: 64
        ack_header_value:
          type: string
          description: Expected acknowledgement header value.
          maxLength: 128
        delivery_sla_seconds:
          type: integer
          maximum: 3600
          minimum: 1
          description: SLA target in seconds for successful delivery acknowledgements.
        escalation_policy:
          description: 'Ordered escalation policy list, e.g. [{"channel": "slack",
            "target": "...", "after_failures": 2}]. Defaults to Slack -> SMS -> PagerDuty
            when empty.'
        filter_condition:
          nullable: true
          description: Optional JSON condition DSL used to route events to this webhook.
        created_at:
          type: string
          format: date-time
          readOnly: true
        last_triggered:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        failure_count:
          type: integer
          readOnly: true
      required:
      - contract
      - contract_id
      - created_at
      - failure_count
      - id
      - last_triggered
      - target_url
  securitySchemes:
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
