              $ref: '#/components/schemas/TokenObtainPair'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenObtainPair'
          description: ''
  /api/token/refresh/:
    post:
      operationId: api_token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /health/:
    get:
      operationId: health_retrieve
      description: Liveness probe - app is running.
      tags:
      - health
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /ready/:
    get:
      operationId: ready_retrieve
      description: Readiness probe - DB and Redis are connected.
      tags:
      - ready
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
components:
  schemas:
    APIKey:
      type: object
      description: |-
        Serializer for APIKey model.
        The ``key`` field is write-once: visible only in the creation response.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 128
        key:
          type: string
          readOnly: true
        tier:
          $ref: '#/components/schemas/TierEnum'
        quota_per_hour:
          type: integer
          readOnly: true
          description: Max requests per hour. Auto-set from tier on creation.
        is_active:
          type: boolean
        last_used_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - id
      - key
      - last_used_at
      - name
      - quota_per_hour
    AdminAction:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        username:
          type: string
          readOnly: true
        action:
          type: string
          maxLength: 128
        object_type:
          type: string
          maxLength: 32
        object_id:
          type: string
          maxLength: 255
        timestamp:
          type: string
          format: date-time
          readOnly: true
        ip_address:
          type: string
        changes: {}
      required:
      - action
      - id
      - object_id
      - object_type
      - timestamp
      - username
    ContractEvent:
      type: object
      description: |-
        Serializer for ContractEvent model.
        Provides read-only details of an indexed event from the Soroban network.
      properties:
        id:
          type: integer
          readOnly: true
        contract_id:
          type: string
          readOnly: true
        contract_name:
          type: string
          readOnly: true
        event_type:
          type: string
          readOnly: true
          description: Event type/name (e.g., 'swap', 'transfer')
        payload:
          readOnly: true
          description: Decoded event payload
        payload_hash:
          type: string
          readOnly: true
          description: SHA-256 hash of the payload
        decoded_payload:
          readOnly: true
          nullable: true
          description: ABI-decoded event payload (human-readable fields)
        decoding_status:
          allOf:
          - $ref: '#/components/schemas/DecodingStatusEnum'
          readOnly: true
          description: |-
            Result of ABI-based XDR decoding

            * `success` - Success
            * `failed` - Failed
            * `no_abi` - No ABI
        ledger:
          type: integer
          readOnly: true
          description: Ledger sequence number
        event_index:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: 0-based event index within the ledger
        timestamp:
          type: string
          format: date-time
          readOnly: true
          description: Event timestamp
        tx_hash:
          type: string
          readOnly: true
          description: Transaction hash
        transaction_id:
          type: string
          readOnly: true
        schema_version:
          type: integer
          readOnly: true
          nullable: true
          description: EventSchema version used for validation (if any)
        validation_status:
          allOf:
          - $ref: '#/components/schemas/ValidationStatusEnum'
          readOnly: true
          description: |-
            Result of schema validation

            * `passed` - Passed
            * `failed` - Failed
        signature_status:
          allOf:
          - $ref: '#/components/schemas/SignatureStatusEnum'
          readOnly: true
          description: |-
            Result of event signature verification

            * `valid` - Valid
            * `invalid` - Invalid
            * `missing` - Missing
      required:
      - contract_id
      - contract_name
      - decoded_payload
      - decoding_status
      - event_type
      - id
      - ledger
      - payload
      - payload_hash
      - schema_version
      - signature_status
      - timestamp
      - transaction_id
      - tx_hash
      - validation_status
    ContractInvocation:
      type: object
      description: |-
        Serializer for ContractInvocation model.
        Provides read-only details of a contract function invocation.
      properties:
        id:
          type: integer
          readOnly: true
        tx_hash:
          type: string
          readOnly: true
          description: Transaction hash
        caller:
          type: string
          readOnly: true
          description: Source account address (G...)
        contract_id:
          type: string
          readOnly: true
        contract_name:
          type: string
          readOnly: true
        function_name:
          type: string
          readOnly: true
          description: Contract function name
        parameters:
          readOnly: true
          description: Function parameters in XDR-encoded form
        result:
          readOnly: true
          nullable: true
          description: Function result in XDR-encoded form
        ledger_sequence:
          type: integer
          readOnly: true
          description: Ledger sequence number
        created_at:
          type: string
          format: date-time
          readOnly: true
          description: Timestamp when record was created
        events_count:
          type: integer
          description: Return count of related events.
          readOnly: true
        events:
          type: array
          items:
            $ref: '#/components/schemas/ContractEvent'
          readOnly: true
      required:
      - caller
      - contract_id
      - contract_name
      - created_at
      - events
      - events_count
      - function_name
      - id
      - ledger_sequence
      - parameters
      - result
      - tx_hash
    ContractStats:
      type: object
      properties:
        total_events:
          type: integer
        unique_event_types:
          type: integer
        latest_ledger:
          type: integer
        last_activity:
          type: string
          format: date-time
        contract_id:
          type: string
        name:
          type: string
      required:
      - contract_id
      - last_activity
      - latest_ledger
      - name
      - total_events
      - unique_event_types
    ContractStatusResponse:
      type: object
      properties:
        total_contracts:
          type: integer
        active_contracts:
          type: integer
        paused_contracts:
          type: integer
        total_events_indexed:
          type: integer
        last_event_timestamp:
          type: string
          format: date-time
          nullable: true
        events_per_minute:
          type: integer
      required:
      - active_contracts
      - events_per_minute
      - last_event_timestamp
      - paused_contracts
      - total_contracts
      - total_events_indexed
    DbPoolStatsResponse:
      type: object
      properties:
        total:
          type: integer
          description: Total live connections for the current database.
        active:
          type: integer
          description: Live connections currently executing queries.
        idle:
          type: integer
          description: Live connections currently idle.
        wait_queue:
          type: integer
          description: Live connections waiting on a database wait event.
      required:
      - active
      - idle
      - total
      - wait_queue
    DecodingStatusEnum:
      enum:
      - success
      - failed
      - no_abi
      type: string
      description: |-
        * `success` - Success
        * `failed` - Failed
        * `no_abi` - No ABI
    DeprecationStatusEnum:
      enum:
      - active
      - deprecated
      - suspended
      type: string
      description: |-
        * `active` - Active
        * `deprecated` - Deprecated
        * `suspended` - Suspended
    EventFilterTypeEnum:
      enum:
      - none
      - whitelist
      - blacklist
      type: string
      description: |-
        * `none` - No Filter
        * `whitelist` - Whitelist
        * `blacklist` - Blacklist
    EventSearch:
      type: object
      description: |-
        Read-only serializer for event search results.
        Includes a ``relevance_score`` placeholder for future ranking support.
      properties:
        id:
          type: integer
          readOnly: true
        contract_id:
          type: string
          readOnly: true
        contract_name:
          type: string
          readOnly: true
        event_type:
          type: string
          readOnly: true
          description: Event type/name (e.g., 'swap', 'transfer')
        payload:
          readOnly: true
          description: Decoded event payload
        payload_hash:
          type: string
          readOnly: true
          description: SHA-256 hash of the payload
        ledger:
          type: integer
          readOnly: true
          description: Ledger sequence number
        event_index:
          type: integer
          readOnly: true
          description: 0-based event index within the ledger
        timestamp:
          type: string
          format: date-time
          readOnly: true
          description: Event timestamp
        tx_hash:
          type: string
          readOnly: true
          description: Transaction hash
        transaction_id:
          type: string
          readOnly: true
        validation_status:
          allOf:
          - $ref: '#/components/schemas/ValidationStatusEnum'
          readOnly: true
          description: |-
            Result of schema validation

            * `passed` - Passed
            * `failed` - Failed
        signature_status:
          allOf:
          - $ref: '#/components/schemas/SignatureStatusEnum'
          readOnly: true
          description: |-
            Result of event signature verification

            * `valid` - Valid
            * `invalid` - Invalid
            * `missing` - Missing
        relevance_score:
          type: number
          format: double
          readOnly: true
      required:
      - contract_id
      - contract_name
      - event_index
      - event_type
      - id
      - ledger
      - payload
      - payload_hash
      - relevance_score
      - signature_status
      - timestamp
      - transaction_id
      - tx_hash
      - validation_status
    HealthCheckResponse:
      type: object
      properties:
        status:
