          type: string
          minLength: 1
      - in: query
        name: limit
        schema:
          type: integer
      - in: query
        name: object_id
        schema:
          type: string
          minLength: 1
      - in: query
        name: object_type
        schema:
          type: string
          minLength: 1
      - in: query
