  /api/ingest/deletion-requests/:
    get:
      operationId: api_ingest_deletion_requests_retrieve
      description: |-
        GET  /api/deletion-requests/   — list all requests (staff) or own requests
        POST /api/deletion-requests/   — submit a new GDPR deletion request
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_ingest_deletion_requests_create
      description: |-
        GET  /api/deletion-requests/   — list all requests (staff) or own requests
        POST /api/deletion-requests/   — submit a new GDPR deletion request
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/ingest/events/:
    get:
      operationId: api_ingest_events_list
      description: |-
        ViewSet for querying indexed events.

        Endpoints:
        - GET /events/ - List all events (paginated)
        - GET /events/{id}/ - Get event details
        - GET /events/search/ - Full-text + field-level search
      parameters:
      - in: query
        name: contract__contract_id
        schema:
          type: string
      - in: query
        name: decoding_status
        schema:
          type: string
          enum:
          - failed
          - no_abi
          - success
        description: |-
          Result of ABI-based XDR decoding

          * `success` - Success
          * `failed` - Failed
          * `no_abi` - No ABI
      - in: query
        name: event_type
        schema:
          type: string
      - in: query
        name: ledger
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: signature_status
        schema:
          type: string
          enum:
          - invalid
          - missing
          - valid
        description: |-
          Result of event signature verification

          * `valid` - Valid
          * `invalid` - Invalid
          * `missing` - Missing
      - in: query
        name: tx_hash
        schema:
          type: string
      - in: query
        name: validation_status
        schema:
          type: string
          enum:
          - failed
          - passed
        description: |-
          Result of schema validation

          * `passed` - Passed
          * `failed` - Failed
      tags:
      - api
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedContractEventList'
          description: ''
  /api/ingest/events/{id}/:
    get:
      operationId: api_ingest_events_retrieve
      description: |-
        ViewSet for querying indexed events.

        Endpoints:
        - GET /events/ - List all events (paginated)
        - GET /events/{id}/ - Get event details
        - GET /events/search/ - Full-text + field-level search
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this contract event.
        required: true
      tags:
      - api
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ContractEvent'
          description: ''
  /api/ingest/events/restore-archive/:
    post:
      operationId: api_ingest_events_restore_archive_create
      description: |-
        Retrieve an archived event batch from S3 and re-import events into PostgreSQL.

        Query params:
        - batch_id: ID of the ArchivedEventBatch to restore
      parameters:
      - in: query
        name: batch_id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RestoreArchiveResponse'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RestoreNotFound'
          description: ''
