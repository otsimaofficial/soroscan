      properties:
        contract_id:
          type: string
          description: Target contract address
          maxLength: 56
        event_type:
          type: string
          description: Event type name
          maxLength: 100
        payload_hash:
          type: string
          description: SHA-256 hash of payload (hex)
          maxLength: 64
      required:
