          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/WebhookSubscription'
    PatchedTeam:
      type: object
      description: Team (multi-tenant organization). Slug is auto-assigned on create.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 128
        slug:
          type: string
          readOnly: true
          pattern: ^[-a-zA-Z0-9_]+$
        created_at:
          type: string
          format: date-time
          readOnly: true
    PatchedTrackedContract:
      type: object
      description: |-
        Serializer for TrackedContract model.
        Used for creating, updating, and returning tracked Soroban smart contracts.
      properties:
        id:
          type: integer
          readOnly: true
        contract_id:
          type: string
          description: Stellar contract address (C...)
          maxLength: 56
        name:
          type: string
          description: Human-readable contract name
          maxLength: 100
        alias:
          type: string
          description: Optional friendly name/alias for easier identification (e.g.
            'Token Transfer Contract')
          maxLength: 256
        description:
          type: string
          description: Optional description
        abi_schema:
          nullable: true
          description: Optional ABI/schema for decoding events
        json_schema:
          nullable: true
          description: Optional JSON Schema used to validate ingested event payloads.
        is_active:
          type: boolean
          description: Whether indexing is active
        deprecation_status:
          allOf:
          - $ref: '#/components/schemas/DeprecationStatusEnum'
          description: |-
            Manual lifecycle/deprecation state for warning users

            * `active` - Active
            * `deprecated` - Deprecated
            * `suspended` - Suspended
        deprecation_reason:
          type: string
          description: Optional reason shown to users when contract is deprecated/suspended
        max_events_per_minute:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
          nullable: true
          description: Max events per minute for ingest-time rate limiting (None =
            unlimited)
        event_filter_type:
          allOf:
          - $ref: '#/components/schemas/EventFilterTypeEnum'
          description: |-
            Ingest filter mode: none = store all events; whitelist = only store listed event types; blacklist = drop listed event types.

            * `none` - No Filter
            * `whitelist` - Whitelist
            * `blacklist` - Blacklist
        event_filter_list:
          description: List of event type names used by the whitelist/blacklist filter.
        metadata:
          description: Custom attributes for storing contract metadata (team, owner,
            cost center, etc.)
        last_indexed_ledger:
          type: integer
          readOnly: true
          nullable: true
          description: Last ledger sequence that was indexed for this contract
        team:
          type: integer
          nullable: true
        event_count:
          type: integer
          readOnly: true
        last_event_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
          description: Timestamp of the last indexed event for this contract
        warnings:
          type: array
          items:
            type: object
            additionalProperties:
              type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
    PatchedWebhookSubscription:
      type: object
      description: |-
        Serializer for WebhookSubscription model.
        Configures endpoints to receive event payloads when matches occur.
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
          description: Contract to monitor
        contract_id:
          type: string
          readOnly: true
        event_type:
          type: string
          description: Event type filter (blank = all events)
          maxLength: 100
        target_url:
          type: string
          format: uri
          description: URL to POST event data to
          maxLength: 200
        is_active:
          type: boolean
        signature_algorithm:
          allOf:
          - $ref: '#/components/schemas/SignatureAlgorithmEnum'
          description: |-
            HMAC algorithm used for X-SoroScan-Signature header.

            * `sha256` - SHA-256
            * `sha1` - SHA-1 (legacy)
        ack_header_name:
          type: string
          description: HTTP response header that must be present to acknowledge receipt.
          maxLength: 64
        ack_header_value:
          type: string
          description: Expected acknowledgement header value.
          maxLength: 128
        delivery_sla_seconds:
          type: integer
          maximum: 3600
          minimum: 1
          description: SLA target in seconds for successful delivery acknowledgements.
        escalation_policy:
          description: 'Ordered escalation policy list, e.g. [{"channel": "slack",
            "target": "...", "after_failures": 2}]. Defaults to Slack -> SMS -> PagerDuty
            when empty.'
        filter_condition:
          nullable: true
          description: Optional JSON condition DSL used to route events to this webhook.
        created_at:
          type: string
          format: date-time
          readOnly: true
        last_triggered:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        failure_count:
          type: integer
          readOnly: true
    RateLimitAnalyticsResponse:
      type: object
      properties:
        window_hours:
          type: integer
        generated_at:
          type: string
          format: date-time
        api_keys: {}
      required:
      - api_keys
      - generated_at
      - window_hours
    RateLimitExceeded:
