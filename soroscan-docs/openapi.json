  /api/ingest/events/search/:
    get:
      operationId: api_ingest_events_search_list
      description: |-
        Full-text and field-level search on contract event payloads.

        Query params:
        - q                 — free-text substring match against JSON payload text
        - contract_id       — filter by contract
        - event_type        — filter by event type
        - payload_contains  — JSON containment sub-string (fast with GIN index)
        - payload_field     — dot-notation field path, e.g. decodedPayload.to
        - payload_op        — operator: eq|neq|gte|lte|gt|lt|contains|startswith|in
        - payload_value     — value for field comparison
        - page / page_size  — pagination (max 1000 per page)
      parameters:
      - in: query
        name: contract__contract_id
        schema:
          type: string
      - in: query
        name: contract_id
        schema:
          type: string
          minLength: 1
      - in: query
        name: decoding_status
        schema:
          type: string
          enum:
          - failed
          - no_abi
          - success
        description: |-
          Result of ABI-based XDR decoding

          * `success` - Success
          * `failed` - Failed
          * `no_abi` - No ABI
      - in: query
        name: event_type
        schema:
          type: string
          minLength: 1
      - in: query
        name: ledger
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - in: query
        name: page
        schema:
          type: integer
      - in: query
        name: page_size
        schema:
          type: integer
      - in: query
        name: payload_contains
        schema:
          type: string
          minLength: 1
      - in: query
        name: payload_field
        schema:
          type: string
          minLength: 1
      - in: query
        name: payload_op
        schema:
          enum:
          - eq
          - neq
          - gte
          - lte
          - gt
          - lt
          - contains
          - startswith
          - in
          type: string
          minLength: 1
        description: |-
          * `eq` - eq
          * `neq` - neq
          * `gte` - gte
          * `lte` - lte
          * `gt` - gt
          * `lt` - lt
          * `contains` - contains
          * `startswith` - startswith
          * `in` - in
      - in: query
        name: payload_value
        schema:
          type: string
          minLength: 1
      - in: query
        name: q
        schema:
          type: string
          minLength: 1
      - in: query
        name: signature_status
        schema:
          type: string
          enum:
          - invalid
          - missing
          - valid
        description: |-
          Result of event signature verification

          * `valid` - Valid
          * `invalid` - Invalid
          * `missing` - Missing
      - in: query
        name: tx_hash
        schema:
          type: string
      - in: query
        name: validation_status
        schema:
          type: string
          enum:
          - failed
          - passed
        description: |-
          Result of schema validation

          * `passed` - Passed
          * `failed` - Failed
      tags:
      - api
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedEventSearchList'
          description: ''
