          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedTrackedContract'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedTrackedContract'
      security:
      - jwtAuth: []
