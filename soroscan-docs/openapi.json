      - member
      type: string
      description: |-
        * `owner` - Owner
        * `admin` - Admin
        * `member` - Member
    SignatureAlgorithmEnum:
      enum:
      - sha256
      - sha1
      type: string
      description: |-
        * `sha256` - SHA-256
        * `sha1` - SHA-1 (legacy)
    SignatureStatusEnum:
      enum:
